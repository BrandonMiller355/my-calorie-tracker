# Copy to .env.local and fill in from the Supabase dashboard (Project Settings → API).
# The publishable key ships in the browser bundle; RLS is the security boundary.
# Never put the secret (sb_secret_...) key here or anywhere in the frontend.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
